# SQLite file. For Plesk, point this OUTSIDE the git-deployed app directory
# (e.g. file:../data/prod.db) so redeploys never wipe it.
DATABASE_URL="file:./dev.db"

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""

# Discord Application used ONLY for signing into this site (see SETUP.md) —
# NOT a widget-owning application. Each user enters their own separate
# Discord Application ID + bot token on their dashboard, since attaching a
# widget only works for that application's owner.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_OAUTH_SCOPE="identify sdk.social_layer"

# Comma-separated Discord user IDs that should be promoted to admin on login
ADMIN_DISCORD_IDS=""

# 32 raw bytes, base64-encoded. Used to encrypt OAuth tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Back this up outside of .env — losing it makes stored tokens unrecoverable.
ENCRYPTION_KEY=""

# How often the URL-source poller checks each enabled source, in seconds
URL_SOURCE_POLL_INTERVAL_SECONDS="60"

PORT="3000"
