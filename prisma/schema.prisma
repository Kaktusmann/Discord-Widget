// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String    @id @default(cuid())
  discordId       String    @unique
  username        String
  discriminator   String?
  avatar          String?
  isAdmin         Boolean   @default(false)
  accessTokenEnc  String?
  refreshTokenEnc String?
  tokenExpiresAt  DateTime?
  // Each user's OWN Discord Application (their own bot) — attaching a widget
  // to a profile only works for that application's owner, so a single shared
  // app can't serve multiple users. See SETUP.md.
  discordAppId          String?
  discordBotTokenEnc    String?
  // Needed to complete the real OAuth2 Authorization Code exchange for
  // sdk.social_layer_presence (see /api/widget/oauth-callback) — this is
  // what actually registers the app<->account identity link that pushed
  // profile data attaches to. Confirmed as the real mechanism (not a client-
  // side console hack) by discordwidgets.com's own setup flow, which asks
  // for this same secret for the same reason.
  discordClientSecretEnc     String?
  discordIdentityAuthorizedAt DateTime?
  // The widget_config created by the "Set up your widget layout" script.
  // Once known, that script switches from POST (create) to PATCH (update the
  // same config in place) — same mechanism discordwidgets.com uses to let
  // people re-edit a layout without accumulating duplicate configs.
  discordWidgetConfigId String?
  // User-customized field-to-slot mapping for their widget_config (see
  // widgetConfigBuilder.ts's WidgetLayoutMapping) — JSON-encoded. Per-user
  // because each person creates their own separate widget_config in their
  // own app, so two people can arrange the same shared fields differently.
  // Falls back to defaultLayoutMapping() when null.
  widgetLayoutJson String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  widgetLink  WidgetLink?
  fieldValues WidgetFieldValue[]
  urlSources  UrlSource[]

  @@map("users")
}

model WidgetLink {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Informational only — the actual push (PATCH .../identities/{id}/profile)
  // doesn't reference a widget_config id at all. Each user designs/owns their
  // own widget_config on their own Discord Application; nothing here needs
  // to read this value back.
  widgetConfigId String?
  published      Boolean   @default(false)
  linkedAt       DateTime?
  unlinkedAt     DateTime?
  lastPushedHash String?
  lastPushedAt   DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("widget_links")
}

model UrlSource {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  url             String
  enabled         Boolean   @default(true)
  lastFetchedAt   DateTime?
  lastFetchedJson String?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fieldValues WidgetFieldValue[]

  @@map("url_sources")
}

model WidgetFieldValue {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldName   String
  fieldType   Int
  value       String?
  dataSource  String     @default("manual") // "manual" | "json_url"
  urlSourceId String?
  urlSource   UrlSource? @relation(fields: [urlSourceId], references: [id], onDelete: SetNull)
  jsonPath    String?
  updatedAt   DateTime   @updatedAt

  @@unique([userId, fieldName])
  @@map("widget_field_values")
}

// Singleton row (id fixed to 1) for site-wide settings an admin manages once.
model AppSettings {
  id Int @id @default(1)

  // A URL template like "https://anilist-widget.rinkerbel.deno.net/user/{username}"
  // — the dashboard's "Add source" box shows a plain username input instead
  // of a raw URL when this is set, substituting it into "{username}". Users
  // can still switch to entering a raw URL directly ("advanced mode").
  defaultSourceUrlTemplate String?

  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model AdminFieldMap {
  id              String   @id @default(cuid())
  fieldName       String   @unique
  fieldType       Int
  label           String
  description     String?
  // Prefilled into the jsonPath input when a user maps this field to a URL
  // source — most users' source JSON shares the same shape, so this saves
  // them from retyping the same path/template every time.
  defaultJsonPath String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("admin_field_map")
}
